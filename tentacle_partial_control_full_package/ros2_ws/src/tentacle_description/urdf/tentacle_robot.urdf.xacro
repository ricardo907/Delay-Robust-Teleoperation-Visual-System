<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tentacle_blade_robot">
  <xacro:property name="base_radius" value="0.18"/>
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="seg_len" value="0.35"/>
  <xacro:property name="seg_rad" value="0.06"/>
  <xacro:property name="finger_len" value="0.18"/>
  <xacro:property name="finger_rad" value="0.02"/>

  <material name="dark_blue"><color rgba="0.15 0.25 0.55 1.0"/></material>
  <material name="soft_purple"><color rgba="0.60 0.45 0.80 1.0"/></material>
  <material name="gray"><color rgba="0.6 0.6 0.6 1.0"/></material>
  <material name="orange"><color rgba="0.95 0.45 0.1 1.0"/></material>
  <material name="red"><color rgba="0.9 0.2 0.2 1.0"/></material>
  <material name="green"><color rgba="0.2 0.75 0.3 1.0"/></material>

  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual><geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry><material name="dark_blue"/></visual>
  </link>

  <joint name="base_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="segment1_link"/>
    <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="segment1_link">
    <visual><origin xyz="0 0 ${seg_len/2.0}" rpy="0 0 0"/><geometry><cylinder radius="${seg_rad}" length="${seg_len}"/></geometry><material name="soft_purple"/></visual>
  </link>

  <joint name="bend_1" type="revolute">
    <parent link="segment1_link"/>
    <child link="segment2_link"/>
    <origin xyz="0 0 ${seg_len}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="1.2" effort="10" velocity="1.0"/>
  </joint>

  <link name="segment2_link">
    <visual><origin xyz="0 0 ${seg_len/2.0}" rpy="0 0 0"/><geometry><cylinder radius="${seg_rad*0.9}" length="${seg_len}"/></geometry><material name="green"/></visual>
  </link>

  <joint name="bend_2" type="revolute">
    <parent link="segment2_link"/>
    <child link="segment3_link"/>
    <origin xyz="0 0 ${seg_len}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="1.2" effort="10" velocity="1.0"/>
  </joint>

  <link name="segment3_link">
    <visual><origin xyz="0 0 ${seg_len/2.0}" rpy="0 0 0"/><geometry><cylinder radius="${seg_rad*0.8}" length="${seg_len}"/></geometry><material name="orange"/></visual>
  </link>

  <joint name="wrist_pitch" type="revolute">
    <parent link="segment3_link"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 ${seg_len}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="1.2" effort="10" velocity="1.0"/>
  </joint>

  <link name="gripper_link">
    <visual><origin xyz="0 0 0.07" rpy="0 0 0"/><geometry><box size="0.12 0.08 0.14"/></geometry><material name="dark_blue"/></visual>
  </link>

  <joint name="left_finger_joint" type="fixed">
    <parent link="gripper_link"/>
    <child link="left_finger"/>
    <origin xyz="0.04 0.04 0.02" rpy="0 0 0"/>
  </joint>

  <link name="left_finger">
    <visual><origin xyz="0 0 ${finger_len/2.0}" rpy="0 0 0"/><geometry><cylinder radius="${finger_rad}" length="${finger_len}"/></geometry><material name="red"/></visual>
  </link>

  <joint name="right_finger_joint" type="fixed">
    <parent link="gripper_link"/>
    <child link="right_finger"/>
    <origin xyz="0.04 -0.04 0.02" rpy="0 0 0"/>
  </joint>

  <link name="right_finger">
    <visual><origin xyz="0 0 ${finger_len/2.0}" rpy="0 0 0"/><geometry><cylinder radius="${finger_rad}" length="${finger_len}"/></geometry><material name="red"/></visual>
  </link>

  <link name="tray_link">
    <visual><origin xyz="0 0 0.05" rpy="0 0 0"/><geometry><box size="0.35 0.24 0.10"/></geometry><material name="gray"/></visual>
  </link>
  <joint name="tray_joint" type="fixed">
    <parent link="world"/>
    <child link="tray_link"/>
    <origin xyz="0.85 -0.45 0.05" rpy="0 0 0"/>
  </joint>

  <link name="fixture_link">
    <visual><origin xyz="0 0 0.12" rpy="0 0 0"/><geometry><box size="0.18 0.14 0.24"/></geometry><material name="red"/></visual>
  </link>
  <joint name="fixture_joint" type="fixed">
    <parent link="world"/>
    <child link="fixture_link"/>
    <origin xyz="0.90 0.00 0.12" rpy="0 0 0"/>
  </joint>

  <link name="recovery_box_link">
    <visual><origin xyz="0 0 0.10" rpy="0 0 0"/><geometry><box size="0.22 0.22 0.20"/></geometry><material name="orange"/></visual>
  </link>
  <joint name="recovery_joint" type="fixed">
    <parent link="world"/>
    <child link="recovery_box_link"/>
    <origin xyz="0.50 0.55 0.10" rpy="0 0 0"/>
  </joint>
</robot>
